CURSOR_API_KEY=your_cursor_api_key_here
PORT=3000
AUTH_USER=your_username
AUTH_PASSWORD=your_password
# Default model when Fast mode is off. "composer-2.5" is fastest for text chat.
# CURSOR_DEFAULT_MODEL=composer-2.5
# Fast mode: Composer 2.5 + fast param for text (set to 0 to disable)
# CURSOR_FAST_MODE=1
# How long to wait if the agent is still running (ms)
# AGENT_BUSY_WAIT_MS=90000
# AGENT_BUSY_POLL_MS=500
# CURSOR_INSECURE_TLS=1
# Max wait for agent to finish before next message (ms). Default 300000 (5 min).
# AGENT_WAIT_MS=300000
